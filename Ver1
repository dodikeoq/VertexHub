local SliderBar = Instance.new("Frame")
SliderBar.Size = UDim2.new(0, 0, 1, 0)
SliderBar.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
SliderBar.BorderSizePixel = 0
SliderBar.Parent = SliderTrack

local isSliding = false
local function HandleSlider()
    local ratio = math.clamp((Mouse.X - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
    local finalVal = math.round((ratio * 5) * 10) / 10 -- Шаг 0.1 секунды, макс 5 секунд
    Config.StealDelay = finalVal
    SliderBar.Size = UDim2.new(ratio, 0, 1, 0)
    SliderLabel.Text = "STEAL DELAY: " .. string.format("%.1f", finalVal) .. "s"
end

SliderTrack.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        isSliding = true
        HandleSlider()
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        isSliding = false
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if isSliding and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
        HandleSlider()
    end
end)

