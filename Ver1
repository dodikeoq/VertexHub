-- Генератор кнопок-переключателей
local function AddToggle(text, configKey)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -4, 0, 32)
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
    btn.BorderColor3 = Color3.fromRGB(30, 30, 35)
    btn.Text = text .. " [OFF]"
    btn.TextColor3 = Color3.fromRGB(240, 70, 70)
    btn.Font = Enum.Font.Code
    btn.TextSize = 11
    btn.Parent = ScrollFrame
    
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 4)
    c.Parent = btn
    
    btn.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]
        if Config[configKey] then
            btn.Text = text .. " [ON]"
            btn.TextColor3 = Color3.fromRGB(0, 255, 150)
            btn.BackgroundColor3 = Color3.fromRGB(16, 26, 20)
            btn.BorderColor3 = Color3.fromRGB(0, 120, 70)
        else
            btn.Text = text .. " [OFF]"
            btn.TextColor3 = Color3.fromRGB(240, 70, 70)
            btn.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
            btn.BorderColor3 = Color3.fromRGB(30, 30, 35)
        end
        UpdateESP()
    end)
end

