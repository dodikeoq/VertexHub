-- Вспомогательная функция поиска ближайшего противника
local function GetClosestPlayer(maxDistance)
    local closestPlayer = nil
    local shortestDistance = maxDistance
    local localChar = LocalPlayer.Character
    local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")
    if not localHRP then return nil end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
            local targetHum = player.Character:FindFirstChildOfClass("Humanoid")
            if targetHRP and targetHum and targetHum.Health > 0 then
                local distance = (localHRP.Position - targetHRP.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestPlayer = player
                end
            end
        end
    end
    return closestPlayer
end

-- 2. Физический импульс отбрасывания (lLte-hit)
RunService.Heartbeat:Connect(function()
    if not Config.LiteHit then return end
    local character = LocalPlayer.Character
    local localHRP = character and character:FindFirstChild("HumanoidRootPart")
    if not localHRP then return end
    
    local targetPlayer = GetClosestPlayer(6)
    local targetHRP = targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if targetHRP then
        local oldVelocity = localHRP.AssemblyLinearVelocity
        local direction = (targetHRP.Position - localHRP.Position).Unit
        local flingForce = direction * 6000 + Vector3.new(0, 2500, 0)
        
        localHRP.AssemblyLinearVelocity = flingForce
        task.wait(0.04)
        if localHRP then
            localHRP.AssemblyLinearVelocity = oldVelocity
        end
    end
end)

-- 3. Автоматизация лазерного плаща
RunService.Heartbeat:Connect(function()
    if not Config.LaserCloak then return end
    local character = LocalPlayer.Character
    if not character then return end
    
    local cloak = character:FindFirstChild("Laser Cloak") or character:FindFirstChild("Лазерный плащ") or 
                  LocalPlayer.Backpack:FindFirstChild("Laser Cloak") or LocalPlayer.Backpack:FindFirstChild("Лазерный плащ")
                  
    if cloak then
        if cloak.Parent == LocalPlayer.Backpack then
            cloak.Parent = character
        end
        cloak:Activate()
    end
end)

-- 4. Мгновенная эвакуация груза (Instant Steal)
local teleportsGuard = false
RunService.Heartbeat:Connect(function()
    if not Config.InstantSteal or teleportsGuard then return end
    local character = LocalPlayer.Character
    local localHRP = character and character:FindFirstChild("HumanoidRootPart")
    if not localHRP then return end
    
    -- Проверка удержания Брейнрота в манипуляторах
    local activeTool = character:FindFirstChildOfClass("Tool")
    local holdingBrainrot = activeTool and (string.find(string.lower(activeTool.Name), "brain") or string.find(string.lower(activeTool.Name), "rot"))
    
    if holdingBrainrot then
        -- Поиск CollectZone принадлежащей Оператору
        local targetZone = nil
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v.Name == "CollectZone" and v:IsA("BasePart") then
                local rootBase = v.Parent
                local isMatch = false
                if rootBase then
                    if string.find(string.lower(rootBase.Name), string.lower(LocalPlayer.Name)) or 
                       (rootBase:FindFirstChild("Owner") and rootBase.Owner.Value == LocalPlayer) or
                       (rootBase.Parent and rootBase.Parent:FindFirstChild("Owner") and rootBase.Parent.Owner.Value == LocalPlayer) then
                        isMatch = true
                    end
                end
                if isMatch then
                    targetZone = v
                    break
                end
            end
        end
        
        if targetZone then
            teleportsGuard = true
            task.wait(Config.StealDelay) -- Задержка по ползунку
            if localHRP and targetZone then
                localHRP.CFrame = targetZone.CFrame + Vector3.new(0, 3, 0)
            end
            task.wait(0.5) -- Окно кулдауна для предотвращения софтлока
            teleportsGuard = false
        end
    end
end)

-- МОДУЛЬ ВИЗУАЛИЗАЦИИ ДАННЫХ ОКРУЖЕНИЯ (ESP)

local function ClearESPGroup(groupName)
    for _, item in ipairs(ESP_Cache[groupName]) do
        if item then item:Destroy() end
    end
    ESP_Cache[groupName] = {}
end

local function UpdateESP()
    -- Игроки
    if Config.ESP_Players then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local id = player.Name
                if not ESP_Cache.Players[id] or not ESP_Cache.Players[id].Parent then
                    local highlight = Instance.new("Highlight")
                    highlight.FillColor = Color3.fromRGB(240, 50, 50)
                    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    highlight.FillTransparency = 0.6
                    highlight.Adornee = player.Character
                    highlight.Parent = targetGui
                    ESP_Cache.Players[id] = highlight
                end
            end
        end
    else
        ClearESPGroup("Players")
    end

    -- Анализ лучшего Брейнрота (Доход в секунду)
    if Config.ESP_Brainrots then
        ClearESPGroup("Brainrots")
        local bestTarget = nil
        local maxIncome = -1
        
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") or obj:IsA("BasePart") then
                local name = string.lower(obj.Name)
                if string.find(name, "brainrot") or string.find(name, "income") or obj:FindFirstChild("Income") then
                    local currentIncome = 0
                    local incVal = obj:FindFirstChild("Income") or obj:FindFirstChild("PerSecond") or obj:GetAttribute("Income")
                    
                    if incVal then
                        currentIncome = tonumber(incVal:IsA("ValueBase") and incVal.Value or incVal) or 0
                    else
                        -- Парсинг из внутренних интерфейсов модели
                        for _, sub in ipairs(obj:GetDescendants()) do
                            if sub:IsA("TextLabel") then
                                local num = string.match(sub.Text, "%d+")
                                if num then currentIncome = tonumber(num) or 0 break end
                            end
                        end
                    end
                    
                    if currentIncome > maxIncome then
                        maxIncome = currentIncome
                        bestTarget = obj
                    end
                end
            end
        end
        
        if bestTarget then
            local billboard = Instance.new("BillboardGui")
            billboard.Size = UDim2.new(0, 160, 0, 40)
            billboard.AlwaysOnTop = true
            billboard.ExtentsOffset = Vector3.new(0, 4, 0)
            billboard.Adornee = bestTarget
            
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.Text = "[⭐ BEST BRAINROT: " .. tostring(maxIncome) .. "/s]"
            label.TextColor3 = Color3.fromRGB(255, 200, 0)
            label.Font = Enum.Font.Code
            label.TextSize = 11
            label.Parent = billboard
            
            billboard.Parent = targetGui
            table.insert(ESP_Cache.Brainrots, billboard)
        end
    else
        ClearESPGroup("Brainrots")
    end

    -- Базы (Таймеры блокировок)
    if Config.ESP_Bases then
        ClearESPGroup("Bases")
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and (string.find(string.lower(obj.Name), "base") or string.find(string.lower(obj.Name), "база") or string.find(string.lower(obj.Name), "tycoon")) then
                local lockTime = "ACTIVE"
                local lockObj = obj:FindFirstChild("Lock", true)
                
                if lockObj then
                    local label = lockObj:IsA("TextLabel") and lockObj or lockObj:FindFirstChildOfClass("TextLabel", true)
                    if label then
                        lockTime = label.Text
                    else
                        local val = lockObj:FindFirstChild("Time") or lockObj:FindFirstChild("Timer")
                        if val then lockTime = tostring(val.Value) end
                    end
                end
                
                local billboard = Instance.new("BillboardGui")
                billboard.Size = UDim2.new(0, 140, 0, 40)
                billboard.AlwaysOnTop = true
                billboard.ExtentsOffset = Vector3.new(0, 6, 0)
                billboard.Adornee = obj
                
                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = "[🔒 BASE // LOCK: " .. lockTime .. "]"
                label.TextColor3 = Color3.fromRGB(0, 180, 255)
                label.Font = Enum.Font.Code
                label.TextSize = 10
                label.Parent = billboard
                
                billboard.Parent = targetGui
                table.insert(ESP_Cache.Bases, billboard)
            end
        end
    else
        ClearESPGroup("Bases")
    end
end

task.spawn(function()
    while true do
        UpdateESP()
        task.wait(1)
    end
end)


