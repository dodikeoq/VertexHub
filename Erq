end

-- Универсальная функция создания ползунка (Переключатель/Ползунок 0-100)
local function createSlider(name, min, max, order, callback)
    local sliderFrame = Instance.new("Frame")
    local sliderLabel = Instance.new("TextLabel")
    local sliderBtn = Instance.new("TextButton")
    local sliderProgress = Instance.new("Frame")
    
    sliderFrame.Size = UDim2.new(1, -16, 0, 45)
    sliderFrame.BackgroundTransparency = 1
    sliderFrame.LayoutOrder = order
    sliderFrame.Parent = ContentScroll
    
    sliderLabel.Size = UDim2.new(1, 0, 0, 20)
    sliderLabel.BackgroundTransparency = 1
    sliderLabel.Text = "  " .. name .. ": " .. min
    sliderLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    sliderLabel.TextXAlignment = Enum.TextXAlignment.Left
    sliderLabel.Font = Enum.Font.SourceSans
    sliderLabel.TextSize = 14
    sliderLabel.Parent = sliderFrame
    
    sliderBtn.Size = UDim2.new(1, -10, 0, 12)
    sliderBtn.Position = UDim2.new(0, 5, 0, 22)
    sliderBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    sliderBtn.Text = ""
    sliderBtn.Parent = sliderFrame
    
    local sliderCorner = Instance.new("UICorner")
    sliderCorner.CornerRadius = UDim.new(0, 4)
    sliderCorner.Parent = sliderBtn
    
    sliderProgress.Size = UDim2.new(0, 0, 1, 0)
    sliderProgress.BackgroundColor3 = Color3.fromRGB(220, 20, 60)
    sliderProgress.Parent = sliderBtn
    
    local progressCorner = Instance.new("UICorner")
    progressCorner.CornerRadius = UDim.new(0, 4)
    progressCorner.Parent = sliderProgress
    
    local function updateSlider(input)
        local pos = math.clamp((input.Position.X - sliderBtn.AbsolutePosition.X) / sliderBtn.AbsoluteSize.X, 0, 1)
        sliderProgress.Size = UDim2.new(pos, 0, 1, 0)
        local value = math.floor(min + (max - min) * pos)
        sliderLabel.Text = "  " .. name .. ": " .. tostring(value)
        callback(value)
    end
    
    local dragging = false
    sliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateSlider(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

